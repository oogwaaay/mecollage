{
  "name": "mecollage",
  "version": "1.0.0",
  "description": "Online image collage maker with support for 20+ images",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:static": "npm run extract-blog-data && vite build && node scripts/generate-static-pages.js",
    "extract-blog-data": "node scripts/extract-blog-data.js",
    "generate-static": "node scripts/generate-static-pages.js",
    "screenshot": "node scripts/generate-screenshot.js",
    "demo-video": "node scripts/generate-demo-video.js",
    "upload-youtube": "node scripts/upload-to-youtube.js",
    "setup-youtube": "node scripts/setup-youtube-oauth.js",
    "preview": "vite preview",
    "deploy": "npm run build:static && gh-pages -d dist"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "form-data": "^4.0.5",
    "gh-pages": "^6.3.0",
    "googleapis": "^128.0.0",
    "open": "^10.2.0",
    "playwright": "^1.56.1",
    "vite": "^5.3.4"
  }
}
